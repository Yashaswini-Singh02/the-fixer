# TxLINE — devnet by default; flip to mainnet values to go live-live
TXLINE_NETWORK=devnet
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
# guest JWT from POST /auth/guest/start (short-lived; refresh on 401)
TXLINE_JWT=
# activated API token from POST /api/token/activate (the durable credential)
TXLINE_API_TOKEN=
# Solana keypair that subscribed on-chain (kept OUTSIDE the repo)
SOLANA_KEYPAIR_PATH=/Users/yashaswini/.config/solana/thefix.json
